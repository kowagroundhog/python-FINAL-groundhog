from pycat.core import Window, Sprite, KeyCode, Scheduler, RotationMode, Player, Color, Label
import random

window = Window(width = 2000, height = 1000)
#shoot = window.create_label()
ammo = window.create_label()
ammo.text = "ammo:30/120"
ememy = window.create_label(x = 200)
ememy.text = "enemy killed : 0"
enemy = 0
speed = 0
autoshoot = 0
# 0 = no
# 1 = shoot
class Player(Sprite):
    
    def on_create(self):
        self.image = "img/player.png"
        self.position = window.center
        self.speed = 10
        self.scale = 0.3
        self.ammo = 30
        self.bullet = 120
        self.time = 1.5
        self.shoot = "yes"
       #shoot.text = "yes"
        #shoot.x = 500
    def on_update(self, dt):
        global autoshoot
        self.time += dt

        if self.time > 1.5:
            self.shoot = "yes"
            #shoot.text = "yes"
            ammo.text = "ammo:"+str(self.ammo)+"/"+str(self.bullet)
        elif self.time < 2:
            ammo.text = "ammo:reloading..."
            self.shoot = "no"
           # shoot.text = "no"
        if self.x < window.mouse_position.x:
            self.scale_x = -1
        else :
            self.scale_x = 1
       
        if self.ammo < 1.5:
            if self.bullet > 30 or self.bullet == 30: 
                if self.shoot == "yes":
                    self.time = 0
                    self.shoot ="no"
                   # shoot.text ="no"
                self.ammo = 30
                self.bullet -= 30
        
        if autoshoot == 1:
            if window.is_key_pressed(KeyCode.SPACE):
                if self.ammo > 0:
                    if self.shoot == "yes":
                        self.ammo -= 1
                        ammo.text = "ammo:"+str(self.ammo)+"/"+str(self.bullet)
                        window.create_sprite(bullet)   
        elif autoshoot == 0:
            if window.is_key_down(KeyCode.SPACE):
                
                if self.ammo > 0:
                    if self.shoot == "yes":
                        self.ammo -= 1
                        ammo.text = "ammo:"+str(self.ammo)+"/"+str(self.bullet)
                        window.create_sprite(bullet)  
        if self.get_touching_sprites_with_tag("army"):
            print("you lose")
            window.close()

