class Gun(Sprite):
    
    def on_create(self):
        global autoshoot
        self.image = random.choice(["AWM.png", "M7.png"])
        if self.image == "AWM.png":
            autoshoot = 0
        elif self.image =="M7.png":
            autoshoot = 1
        self.scale_x = -1
        self.layer = 1
        self.scale = 0.35
        self.position = player.position
        self.y -=20
    def on_update(self, dt):
        self.point_toward_mouse_cursor()
        if self.x > window.mouse_position.x:
            self.scale_y = -1
        else :
            self.scale_y = 1
        
player = window.create_sprite(player)
gun = window.create_sprite(Gun)


class bullet(Sprite):
    global ammo
    def on_create(self):
        
        self.scale = 10
        self.color = Color.YELLOW
        self.position = gun.position
        self.speed = 5
        self.point_toward_mouse_cursor()
        self.add_tag('bullet')
  

    def on_update(self, dt):
        self.move_forward(self.speed)
        
        if self.is_touching_window_edge():
            self.delete()

window.run()
        