class Gun(Sprite):
    
    def on_create(self):
        global autoshoot
        self.image = random.choice(["AWM.png", "M7.png"])
        if self.image == "AWM.png":
            autoshoot = 0
        elif self.image =="M7.png":
            autoshoot = 1
        self.scale_x = -1
        self.layer = 1
        self.scale = 0.35
        self.position = player.position
        self.y -=20
    def on_update(self, dt):
        self.point_toward_mouse_cursor()
        if self.x > window.mouse_position.x:
            self.scale_y = -1
        else :
            self.scale_y = 1
        
player = window.create_sprite(Player)
gun = window.create_sprite(Gun)


class bullet(Sprite):
    global ammo, enemy
    def on_create(self):
        
        self.scale = 10
        self.color = Color.YELLOW
        self.position = gun.position
        self.speed = 10
        self.point_toward_mouse_cursor()
        self.add_tag('bullet')
       

    def on_update(self, dt):
        self.move_forward(self.speed)
        
        if self.is_touching_window_edge():
            self.delete()
       

class Enemy(Sprite):
    def on_create(self):
        self.scale = 35
        self.color = Color.RED
        self.goto_random_position_in_region(min_x = 0, min_y = 0, max_x=2000, max_y=250)
        self.rotation = random.randint(0, 360)
        self.add_tag("army")
    def on_update(self, dt):
        global enemy
        ememy.text = ("enemy killed : " + str(enemy))
        if self.get_touching_sprites_with_tag("bullet"):
            enemy += 1
            self.delete()

        if self.is_touching_sprite(player):
            self.delete()
        if self.x < 10 or self.y < 10 or self.y > 950 or self.x > 1950:
            self.delete()
        self.move_forward(5)

def make_army():
    window.create_sprite(Enemy)

Scheduler.update(make_army, 0.7)
window.run()
        