from pycat.core import Window, Sprite, KeyCode, Scheduler, RotationMode, Player, Color, Label
import random

window = Window()
shoot = window.create_label()
ammo = window.create_label()
ammo.text = "ammo:30/120"
speed = 0

class player(Sprite):
    
    def on_create(self):
        self.image = "img/player.png"
        self.position = window.center
        self.speed = 10
        self.scale = 0.2
        self.ammo = 30
        self.bullet = 120
        self.time = 1.5
        self.shoot = "yes"
        shoot.text = "yes"
        shoot.x = 500
    def on_update(self, dt):
        self.time += dt

        if self.time > 1.5:
            self.shoot = "yes"
            shoot.text = "yes"
            ammo.text = "ammo:"+str(self.ammo)+"/"+str(self.bullet)
        elif self.time < 2:
            ammo.text = "ammo:reloading..."
            self.shoot = "no"
            shoot.text = "no"
        print(self.time)
        if self.ammo < 1.5:
            if self.bullet > 30 or self.bullet == 30: 
                if self.shoot == "yes":
                    self.time = 0
                    self.shoot ="no"
                    shoot.text ="no"
                self.ammo = 30
                self.bullet -= 30
    def on_left_click_anywhere(self):
        if self.ammo > 0:
            if self.shoot == "yes":
                self.ammo -= 1
                ammo.text = "ammo:"+str(self.ammo)+"/"+str(self.bullet)
                window.create_sprite(bullet)    
        
class Gun(Sprite):
    def on_create(self):
        self.image = random.choice(["AWM.png", "M7.png"])
        self.scale = 0.2
        self.position = player.position
    def on_update(self, dt):
        self.point_toward_mouse_cursor()
        
        

player = window.create_sprite(player)
gun = window.create_sprite(Gun)


class bullet(Sprite):
    global ammo
    def on_create(self):
        
        self.scale = 10
        self.color = Color.YELLOW
        self.position = player.position
        self.speed = 5
        self.point_toward_mouse_cursor()
        self.add_tag('bullet')
  

    def on_update(self, dt):
        self.move_forward(self.speed)
        
        if self.is_touching_window_edge():
            self.delete()

window.run()
        